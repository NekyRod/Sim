# URL del servicio de autenticación (para validar tokens o redirigir)
# Valor local: http://localhost:8000
AUTH_SERVICE_URL=http://localhost:8000

# URL para obtener el token de acceso
# Valor local: http://localhost:8000/auth/token
TOKEN_URL=http://localhost:8000/auth/token

# URL del frontend (para configurar CORS)
# Valor local: http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Algoritmo de firma para JWT
# Valor típico: HS256
ALGORITHM=HS256

# Clave Fernet para desencriptar el archivo 'app/config/jwt.conf' que contiene el secreto JWT real.
# Debe ser una clave válida de Fernet (32 url-safe base64-encoded bytes).
# Si falta, la aplicación fallará al intentar leer jwt.conf.
# Ejemplo (NO USAR EN PRODUCCIÓN): enN5IJjlZFG6m5POWpGVentVRg6sRBmsk4pUO5yaaw4=
JWT_FERNET_KEY=
