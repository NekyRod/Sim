# =============================================================================
# GOI SIM-ODONT — Variables de Entorno (Desarrollo Docker)
# =============================================================================
# Instrucciones:
#   1. Copie este archivo como .env:  cp .env.example .env
#   2. Complete TODOS los valores marcados con CHANGE_ME
#   3. Este archivo NO se sube al repositorio (.gitignore)
# =============================================================================

# ── Base de Datos ────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_DB=sim
POSTGRES_USER=admiSim
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_PORT=5432

# ── JWT (Autenticación) ─────────────────────────────
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
JWT_SECRET=CHANGE_ME_RANDOM_STRING_MIN_32_CHARS

# Clave Fernet para cifrar/descifrar la configuración JWT
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_FERNET_KEY=CHANGE_ME_FERNET_KEY

# Algoritmo de firma JWT
ALGORITHM=HS256

# ── URLs de Servicios (Docker interno) ───────────────
# El frontend accede a los backends desde el HOST, no desde la red Docker
FRONTEND_URL=http://localhost
AUTH_SERVICE_URL=http://auth:8000
TOKEN_URL=http://auth:8000/auth/token
