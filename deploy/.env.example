# =============================================================================
# GOI SIM-ODONT — Variables de Entorno (Producción)
# =============================================================================
# Instrucciones:
#   1. Copie este archivo como .env:  cp .env.example .env
#   2. Complete TODOS los valores marcados con CHANGE_ME
#   3. Este archivo NO SE EXPONE en el repositorio
# =============================================================================

# ── Base de Datos ────────────────────────────────────
# Contraseña del usuario "admiSim" en PostgreSQL
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ── JWT (Autenticación) ─────────────────────────────
# Clave secreta para firmar tokens JWT (mínimo 32 caracteres)
JWT_SECRET=CHANGE_ME_RANDOM_STRING_MIN_32_CHARS

# Clave Fernet para cifrar/descifrar la configuración JWT
# Generar con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
JWT_FERNET_KEY=CHANGE_ME_FERNET_KEY

# ── URLs (Opcional) ─────────────────────────────────
# URL pública del frontend (usada por CORS en el backend)
# En producción con Nginx proxy, esto es la URL pública del servidor
FRONTEND_URL=http://your-server-ip-or-domain

# ── Logging ─────────────────────────────────────────
# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
# En producción se recomienda WARNING para reducir ruido
LOG_LEVEL=WARNING
